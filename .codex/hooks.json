        "hooks": [
          {
            "type": "command",
            "command": "python3 .harness/hooks/policy_hook.py PreToolUse codex"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .harness/hooks/policy_hook.py PostToolUse codex"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .harness/hooks/policy_hook.py Stop codex"
          }
        ]
      }
    ]
  }
}
