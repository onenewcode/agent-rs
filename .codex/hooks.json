{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/user_prompt_submit_policy.py",
            "statusMessage": "Checking plan-first policy"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/pre_tool_use_policy.py",
            "statusMessage": "Checking Bash policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/post_tool_use_review.py",
            "statusMessage": "Reviewing Bash output"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.codex/hooks/stop_continue.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
