{
  "hooks": {
    "BeforeAgent": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/user_prompt_submit_policy.py",
            "statusMessage": "Checking plan-first policy"
          }
        ]
      }
    ],
    "BeforeTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/pre_tool_use_policy.py",
            "statusMessage": "Checking tool policy"
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/post_tool_use_review.py",
            "statusMessage": "Reviewing tool output"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/stop_continue.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
